{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "types": ["cypress", "@testing-library/cypress", "node"]
  },
  "include": ["./e2e/**/*.ts", "./support/**/*.ts", "../cypress.config.ts"]
}
